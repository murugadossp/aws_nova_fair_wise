# FareWise — Environment variables (copy to .env, never commit .env)

# AWS credentials (Bedrock access required)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# Nova Act — IAM mode (uses AWS credentials above, no API key needed)
# NOVA_ACT_API_KEY must NOT be set — it conflicts with IAM auth via Workflow class

# S3 bucket for Nova Act workflow artifacts (must exist in your AWS account)
NOVA_ACT_S3_BUCKET=fair-wise

# Workflow definition names (optional — defaults shown, override if needed)
# NOVA_ACT_WORKFLOW_AMAZON=farewise-amazon
# NOVA_ACT_WORKFLOW_FLIPKART=farewise-flipkart
# NOVA_ACT_WORKFLOW_MMT=farewise-makemytrip
# NOVA_ACT_WORKFLOW_GOIBIBO=farewise-goibibo
# NOVA_ACT_WORKFLOW_CLEARTRIP=farewise-cleartrip

# Backend config
FAREWISE_PORT=8000
FAREWISE_CORS_ORIGINS=chrome-extension://*,http://localhost:*,http://127.0.0.1:*

# Set to 1 to show Nova Act browser window during agent runs (default: 0 = headless)
# FAREWISE_HEADED=0

# Max steps per Nova Act extraction (default 50; SDK max 99). Increase if agents often hit limit.
# NOVA_ACT_MAX_STEPS=50

# Optional: Sentry DSN for error tracking in production
# SENTRY_DSN=https://...
